# Mazza Finance — Caddy Reverse Proxy Configuration
#
# HTTPS CERTIFICATE SETUP (choose one):
#
# Option A — mkcert (recommended for home network):
#   1. Install mkcert: brew install mkcert
#   2. mkcert -install
#   3. mkcert localhost 127.0.0.1
#   4. Update the tls block below to reference the generated files
#   5. Install the mkcert CA on Mrs. Mazza's devices (see README)
#
# Option B — Let's Encrypt (requires a real domain with public DNS):
#   Replace the tls block with: tls your@email.com
#
# After changing the TLS strategy, run: docker compose restart caddy

# HTTP → HTTPS redirect
http:// {
    redir https://{host}{uri} permanent
}

# Main HTTPS site
{$CADDY_DOMAIN} {

    # TLS — mkcert certificates bind-mounted via docker-compose.yml volumes
    # Caddy enforces TLS 1.2+ by default; no extra protocols directive needed
    tls /certs/localhost.pem /certs/localhost-key.pem

    # HTTP Basic Auth on all routes
    # Credentials set in .env as CADDY_BASIC_AUTH_HASH
    # Generate hash: caddy hash-password --plaintext <yourpassword>
    basicauth * {
        mazza {$CADDY_BASIC_AUTH_HASH}
    }

    # Security headers
    header {
        Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-yEEXl9HDMsJ4Ql6k8z8LV0ixwFiQCQXFxBjZie/zWdo=' https://cdn.teller.io; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.teller.io; connect-src 'self' https://api.teller.io; frame-src https://teller.io https://cdn.teller.io https://connect.teller.io; object-src 'none'; frame-ancestors 'none'"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # API reverse proxy
    handle /api/* {
        reverse_proxy backend:3001
    }

    # Frontend SPA — all other routes serve index.html
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }
}
