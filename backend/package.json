  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.5.0",
    "drizzle-kit": "^0.20.18",
