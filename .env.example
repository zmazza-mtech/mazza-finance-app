# =============================================================================
# Mazza Finance — Environment Configuration
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control — it is blocked by .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres superuser password (used only during first-time initialization)
POSTGRES_PASSWORD=changeme_strong_postgres_password

# Application runtime user password (least privilege — DML only)
POSTGRES_APP_PASSWORD=changeme_strong_app_password

# Full connection string for the backend (uses mazza_app runtime user)
DATABASE_URL=postgresql://mazza_app:changeme_strong_app_password@postgres:5432/mazza_finance

# -----------------------------------------------------------------------------
# teller.io
# -----------------------------------------------------------------------------

# Absolute HOST paths to teller.io certificate files.
# These are bind-mounted into the backend container at runtime.
# NEVER place these inside the project directory.
#
# On this machine the certs live at:
#   ~/.ssh/teller_public_certificate.pem  (permissions: 644)
#   ~/.ssh/teller_private_key.pem         (permissions: 600)
#
# Verify permissions:
#   ls -la ~/.ssh/teller_public_certificate.pem ~/.ssh/teller_private_key.pem
# Fix if needed:
#   chmod 600 ~/.ssh/teller_private_key.pem
#   chmod 644 ~/.ssh/teller_public_certificate.pem
TELLER_CERT_PATH=/Users/zac-momoski-tech/.ssh/teller_public_certificate.pem
TELLER_KEY_PATH=/Users/zac-momoski-tech/.ssh/teller_private_key.pem

# sandbox | production
TELLER_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# AES-256-GCM key for encrypting teller.io access tokens at rest.
# Generate a new key with: openssl rand -hex 32
# Keep this secret. If it is lost, stored tokens cannot be decrypted
# and teller.io must be re-enrolled.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

PORT=3001
NODE_ENV=production

# CORS allowed origin — must match the exact origin Caddy serves.
# No trailing slash. Examples: https://localhost, https://finance.home
CORS_ORIGIN=https://localhost

# -----------------------------------------------------------------------------
# Caddy
# -----------------------------------------------------------------------------

# The hostname Caddy should respond to (matches your TLS certificate)
CADDY_DOMAIN=localhost

# HTTP Basic Auth password hash for the "mazza" user.
# Generate with: caddy hash-password --plaintext <yourpassword>
# Paste the full $2a$... bcrypt hash here.
CADDY_BASIC_AUTH_HASH=

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variables — prefix VITE_)
# -----------------------------------------------------------------------------

VITE_API_BASE_URL=https://localhost/api/v1
